<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../includes/head.ejs') %>
  </head>
  <body>
    <div class="max-w-3xl m-auto mt-4 space-y-4">
      <form action="/admin/new" method="post" class="w-full space-y-4">
        <div class="flex justify-between items-center">
          <h1 class="text-4xl">New Article</h1>
          <button
            type="submit"
            class="cursor-pointer border border-blue-200 px-2 py-1 rounded bg-blue-100 hover:bg-blue-200"
          >
            Publish
          </button>
        </div>
        <div class="">
          <label for="articelTitle" class="hidden"></label>
          <input
            type="text"
            name="articelTitle"
            id="articelTitle"
            placeholder="Article Title"
            class="py-1 w-full border-b border-gray-50 focus:border-gray-200 focus:outline-none"
          />
        </div>

        <div class="">
          <label for="publishDate" class="hidden"></label>
          <input
            type="date"
            value="<%= publishDate %>"
            name="publishDate"
            id="publishDate"
            disabled
          />
        </div>

        <div class="">
          <label for="content" class="hidden"></label>
          <textarea
            name="content"
            id="content"
            placeholder="Content"
            class="h-screen w-full outline-none"
          ></textarea>
        </div>
      </form>
    </div>
  </body>
</html>
