<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../includes/head.ejs') %>
  </head>
  <body>
    <div class="max-w-3xl m-auto mt-4 space-y-4">
      <form
        action="/admin/edit/<%= article.id%>"
        method="post"
        class="w-full space-y-4"
      >
        <div class="flex justify-between items-center">
          <h1 class="text-4xl">Update Article</h1>
          <button
            type="submit"
            class="cursor-pointer border border-blue-200 px-2 py-1 rounded bg-blue-100 hover:bg-blue-200"
          >
            Update
          </button>
        </div>
        <div class="">
          <label for="articleTitle" class="hidden"></label>
          <input
            type="text"
            name="articleTitle"
            id="articleTitle"
            value="<%= article.articleTitle%>"
            class="py-1 w-full border-b border-gray-50 focus:border-gray-200 focus:outline-none"
          />
        </div>

        <div class="">
          <label for="publishDate" class="hidden"></label>
          <input
            type="date"
            value="<%= article.publishDate%>"
            name="publishDate"
            id="publishDate"
            readonly
          />
        </div>

        <div class="">
          <label for="content" class="hidden"></label>
          <textarea
            name="content"
            id="content"
            class="h-screen w-full outline-none"
          >
            <%= article.content%>
          </textarea>
        </div>
      </form>
    </div>
  </body>
</html>
