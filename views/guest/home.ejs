<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../includes/head.ejs') %>
  </head>
  <body>
    <div class="max-w-3xl m-auto mt-4 space-y-4">
      <div class="flex justify-between items-center pb-4 border-b border-gray-200">
        <h1 class="text-4xl">Personal Blog</h1>
        <a href="/admin" class="text-xl py-1 px-2 rounded-full border-transparent hover:bg-gray-200"><i class="ph ph-user"></i></a>
      </div>

      <ul class="flex flex-col gap-1">
        
        <% for(let article of articles){%>
          <li class="flex justify-between items-center py-2 px-1 rounded cursor-pointer hover:bg-gray-100">
            <a class="flex-1" href="/article/<%= article.id%>"><%= article.articleTitle%></a>
            <span class="text-gray-500"><%= new Date(article.publishDate).toLocaleString("en-US", {day: "numeric", month: "short", year: "numeric"})%></span>
          </li>
        <%}%>
      
      </ul>
    </div>
  </body>
</html>
